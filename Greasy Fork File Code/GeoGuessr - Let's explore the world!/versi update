        document.getElementById('geohelper-settings-back')?.addEventListener('click', () => swapToView('menu'));
        document.getElementById('geohelper-hotkeys-back')?.addEventListener('click', () => swapToView('menu'));
        document.getElementById('geohelper-discord-back')?.addEventListener('click', () => swapToView('menu'));
        document.getElementById('geohelper-copy-back')?.addEventListener('click', () => swapToView('menu'));
        document.getElementById('geohelper-maps-back')?.addEventListener('click', () => swapToView('menu'));
