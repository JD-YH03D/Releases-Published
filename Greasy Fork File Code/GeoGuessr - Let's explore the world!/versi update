    // ========================================================================
    // [SECTION 18-B] GAME MAP PIN ENGINE
    // ========================================================================
    // Original implementation by Bintang Toba Pro
    //
    // Technique: We traverse the React component tree attached to the guess-map
    // DOM node, locate the Google Maps instance held in memoizedProps, then
    // inspect its internal event listener registry to programmatically fire the
    // same callback the game fires when a player clicks the map.  The coordinate
    // payload is wrapped in a synthetic object whose shape mirrors the Google
    // Maps MouseEvent, so the game's own handler cannot distinguish our call
    // from a genuine click.
    //
    // This approach is entirely derived from public React / Google Maps APIs
    // and does not copy any third-party script source code.
    // ========================================================================

    /**
     * Traverse a DOM element's React Fiber tree upward and collect every
     * Google Maps instance found along the way.
     *
     * @param {HTMLElement} domNode – a DOM node that belongs to the React app
     * @param {number}      maxDepth – how many `.return` hops to try
     * @returns {Object|null} Google Maps instance (with .__e3_ registry) or null
     */
    function resolveGoogleMapFromFiber(domNode, maxDepth = 8) {
        if (!domNode) return null;

        // Find the Fiber node attached to this DOM element
        const fiberKey = Object.keys(domNode).find(k =>
                                                   k.startsWith('__reactFiber$') || k.startsWith('__reactInternalInstance$')
                                                  );
        if (!fiberKey) return null;

        let fiber = domNode[fiberKey];

        // Walk upward through the Fiber tree looking for a memoizedProps.map
        for (let depth = 0; fiber && depth < maxDepth; depth++) {
            try {
                const props = fiber.memoizedProps;
                if (props?.map && typeof props.map === 'object') {
                    // Verify it really is a Google Maps instance
                    if (props.map.__e3_ || props.map.getCenter || props.map.setCenter) {
                        return props.map;
                    }
                }
                // Also check stateNode for class components
                if (fiber.stateNode?.map && fiber.stateNode.map.__e3_) {
                    return fiber.stateNode.map;
                }
            } catch (_) { /* guard against sealed props */ }

            fiber = fiber.return;
        }

        return null;
    }

    /**
     * Build a synthetic Google Maps click-event payload.
     * The game handler reads `e.latLng.lat()` and `e.latLng.lng()` —
     * we only need to satisfy that interface.
     *
     * @param {number} lat
     * @param {number} lng
     * @returns {Object}
     */
    function buildSyntheticMapEvent(lat, lng) {
        return {
            latLng: {
                lat: () => lat,
                lng: () => lng,
                toJSON: () => ({ lat, lng }),
                toString: () => `(${lat}, ${lng})`
            },
            stop: null,
            pixel: null // some handlers look at pixel, null is safe
        };
    }

    /**
     * Given a Google Maps instance, fire every registered "click" callback
     * with our synthetic event.
     *
     * @param {Object} mapInst – Google Maps instance
     * @param {Object} syntheticEvent – from buildSyntheticMapEvent()
     * @returns {boolean} true if at least one handler was invoked
     */
    function dispatchToClickListeners(mapInst, syntheticEvent) {
        // Google Maps stores listeners in an internal registry keyed by
        // event name. The exact property has varied across versions:
        // __e3_, __e3_destroyed_, __listeners_ etc.  We try all known ones.
        const registryKeys = ['__e3_', '__listeners_', 'gm_bindings_'];
        let invoked = false;

        for (const regKey of registryKeys) {
            const registry = mapInst[regKey];
            if (!registry || typeof registry !== 'object') continue;

            const clickBucket = registry.click;
            if (!clickBucket || typeof clickBucket !== 'object') continue;

            // clickBucket is a dict-of-dicts: { listenerID: { handler: fn } }
            const bucketKeys = Object.keys(clickBucket);
            for (let i = bucketKeys.length - 1; i >= 0; i--) {
                const entry = clickBucket[bucketKeys[i]];
                if (!entry || typeof entry !== 'object') continue;

                const fnKeys = Object.keys(entry);
                for (const fk of fnKeys) {
                    if (typeof entry[fk] === 'function') {
                        try {
                            entry[fk](syntheticEvent);
                            invoked = true;
                            Logger.debug(`dispatchToClickListeners: invoked handler [${regKey}][${bucketKeys[i]}][${fk}]`);
                        } catch (err) {
                            Logger.debug('dispatchToClickListeners: handler threw', err.message);
                        }
                    }
                }
            }

            if (invoked) break; // one registry is enough
        }

        return invoked;
    }

    /**
     * Locate the guess-map DOM node for the current game mode.
     *
     * GeoGuessr renders different map components depending on the game mode
     * (classic, streaks, duels, etc.).  We maintain a priority-ordered list
     * of CSS selectors and return the first visible match.
     *
     * @returns {HTMLElement|null}
     */
    function locateGuessMapNode() {
        const candidates = [
            // Classic / challenge modes
            '[class^="guess-map_canvas"]',
            '[class*="guess-map_canvas"]',
            '[data-qa="guess-map"] [class*="canvas"]',
            // Streaks / region modes
            '[class*="region-map_mapCanvas"]',
            '[class*="region-map_canvas"]',
            // Generic fallbacks
            '[class*="map_canvas__"]',
            '[class*="mapCanvas__"]'
        ];

        for (const sel of candidates) {
            const nodes = document.querySelectorAll(sel);
            for (const node of nodes) {
                const r = node.getBoundingClientRect();
                if (r.width > 30 && r.height > 30) return node;
            }
        }

        return null;
    }

    /**
     * High-level function: pin a guess on the game map.
     *
     * Flow:
     *  1. Locate the guess-map DOM node.
     *  2. Resolve the Google Maps instance from React Fiber.
     *  3. Build a synthetic click event carrying our coordinates.
     *  4. Fire every registered click listener so the game records the guess.
     *
     * @param {number} lat
     * @param {number} lng
     * @returns {boolean}
     */
    function pinGuessToGameMap(lat, lng) {
        // Step 1 — find the DOM node
        const mapNode = locateGuessMapNode();
        if (!mapNode) {
            Logger.debug('pinGuessToGameMap: guess-map node not found');
            return false;
        }

        // Step 2 — resolve the Google Maps object
        const gMapInst = resolveGoogleMapFromFiber(mapNode, 10);
        if (!gMapInst) {
            Logger.debug('pinGuessToGameMap: Google Maps instance not found in Fiber');
            return false;
        }

        // Step 3 — create the synthetic event
        const synEvent = buildSyntheticMapEvent(lat, lng);

        // Step 4 — dispatch
        const ok = dispatchToClickListeners(gMapInst, synEvent);

        if (ok) {
            Logger.debug('pinGuessToGameMap: successfully dispatched at', lat.toFixed(6), lng.toFixed(6));
        } else {
            Logger.debug('pinGuessToGameMap: no click listeners accepted the event');
        }

        return ok;
    }

    /**
     * Apply a randomised offset to coordinates.
     * Returns a new {lat, lng} without mutating the input.
     *
     * The offset is drawn uniformly from a disc of radius ~CONFIG.MAP.SAFE_MODE_OFFSET_DEGREES
     * (≈ 50 m at the equator) so the result feels natural rather than grid-aligned.
     *
     * @param {number} lat
     * @param {number} lng
     * @returns {{ lat: number, lng: number }}
     */
    function jitterCoordinates(lat, lng) {
        const maxR = CONFIG.MAP.SAFE_MODE_OFFSET_DEGREES;
        // Uniform sampling inside a circle (square-root trick)
        const angle = Math.random() * 2 * Math.PI;
        const radius = maxR * Math.sqrt(Math.random());
        return {
            lat: lat + radius * Math.cos(angle),
            lng: lng + radius * Math.sin(angle)
        };
    }

    /**
     * Entry-point called when Auto-Click Mode is ON and the user presses
     * the autoPlace / safePlace hotkey.
     *
     * @param {boolean} withJitter – true ⇒ apply random offset (safe mode)
     * @returns {boolean}
     */
    function placeGuessOnMap(withJitter = false) {
        if (!guardProtectedUsage('Place Guess')) return false;

        const raw = extractCoordinates();
        if (!raw || !Validators.isValidCoord(raw.lat, raw.lng)) {
            updateStatusText('No coords', '#ef4444');
            return false;
        }

        const target = withJitter ? jitterCoordinates(raw.lat, raw.lng) : raw;

        const ok = pinGuessToGameMap(target.lat, target.lng);

        if (ok) {
            state.markerPlacedThisRound = true;
            updateStatusText(withJitter ? 'Safe Pinned!' : 'Pinned!', '#4ade80');
            updateLedIndicator('ready');
            Logger.info('📌 Guess pinned on game map',
                        withJitter ? '(jittered)' : '(exact)',
                        target.lat.toFixed(6), target.lng.toFixed(6));
        } else {
            updateStatusText('Pin failed', '#ef4444');
            Logger.warn('placeGuessOnMap: could not pin guess');
        }

        return ok;
    }

    /**
     * Find game map instance via React Fiber
     * @returns {boolean}
     */
    function findMapInstance() {
        try {
            const selectors = [
                "[class*='guess-map_canvas']",
                ".leaflet-container",
                "[class*='mapCanvas']",
                "[class*='map-canvas']",
                "[data-qa*='map']",
                "[id*='map']"
            ];

            const containers = document.querySelectorAll(selectors.join(', '));

            for (const container of containers) {
                const fiberKey = Object.keys(container).find(k => k.startsWith('__reactFiber'));
                if (fiberKey) {
                    const fiber = container[fiberKey];
                    state.gameMap = fiber.return?.memoizedProps?.map ||
                        fiber.return?.return?.memoizedProps?.map ||
                        fiber.child?.memoizedProps?.value?.map ||
                        null;
                    if (state.gameMap) {
                        Logger.debug('Map found via React Fiber');
                        return true;
                    }
                }
            }
        } catch (e) {
            Logger.error('Map find error:', e);
        }
        return false;
    }

