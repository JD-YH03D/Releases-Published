    const Security = {
        /**
         * Escape HTML to prevent XSS
         * @param {string} text
         * @returns {string}
         */
        escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = String(text);
            return div.innerHTML;
        },

        /**
         * Escape attribute value
         * @param {string} text
         * @returns {string}
         */
        escapeAttr(text) {
            return this.escapeHtml(text).replace(/"/g, '&quot;');
