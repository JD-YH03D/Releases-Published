    /**
     * Normalize theme mode
     * @param {string} mode
     * @returns {string}
     */
    function normalizeThemeMode(mode) {
        if (mode === 'oneui') return 'dark';
        if (mode === 'classic') return 'colorful';
        return Validators.isValidTheme(mode) ? mode : CONFIG.DEFAULTS.THEME;
    }

    /**
     * Apply theme mode
     * @param {string} themeMode
     * @param {boolean} persist
     */
    function applyThemeMode(themeMode, persist = false) {
        const next = normalizeThemeMode(themeMode);
        state.themeMode = next;
        setThemeButtonsUi();

        const panel = document.getElementById('geohelper-phone-frame');
        if (panel) applyPhoneLikeButtonTheme(panel);

        if (persist) {
            safeGM_setValue(CONFIG.STORAGE_KEYS.THEME, state.themeMode);
